      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ JSON.stringify({ response: $json.response, transcribed_text: $json.transcribed_text, error: true, timestamp: $json.timestamp }) }}",
        "options": {
          "responseCode": 200
        }
      },
      "name": "Error Respond to Webhook",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [
