    {
      "parameters": {
        "jsCode": "const err = $input.first().json;\nconst errorMessage = err.error?.message || err.message || 'An unexpected error occurred';\nconst nodeName = err.execution?.lastNodeExecuted || 'unknown node';\n\nconsole.error('[Voice Assistant Error]', nodeName, errorMessage);\n\nreturn {\n  response: 'I am sorry, I encountered a technical issue and could not complete your request. Please try again.',\n  transcribed_text: '',\n  error: true,\n  error_detail: errorMessage,\n  failed_node: nodeName,\n  timestamp: new Date().toISOString()\n};"
      },
      "name": "Build Error Response",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        64,
        800
      ],
      "id": "node_18"
    },

