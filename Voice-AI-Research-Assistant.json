        "columns": {
          "mappingMode": "defineBelow",
          "value": {
            "SessionID": "={{ $json.session_id }}",
            "Query": "={{ $json.query }}",
            "Intent": "={{ $json.intent }}",
            "Language": "={{ $json.language }}",
            "Timestamp": "={{ new Date().toISOString() }}"
          }
