        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ query: $node[\"Parse Intent\"].json.query, max_results: 5 }) }}",
        "options": {}
      },
      "name": "Search Web (Tavily)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        1312,
        0
      ],
      "id": "node_21",
      "continueOnFail": true
    },

    {
      "parameters": {
        "jsCode": "const tavilyResponse = $node[\"Search Web (Tavily)\"].json;\n\nif (tavilyResponse.error || !tavilyResponse.results) {\n  return {\n    error: true,\n    pipeline: \"research\",\n    message: \"I'm sorry, I couldn't retrieve that information right now.\"\n  };\n}\n\nreturn {\n  results: tavilyResponse.results.slice(0, 5).map(r => ({\n    title: r.title,\n    snippet: r.content,\n    url: r.url\n  }))\n};"
      },
      "name": "Format Tavily Results",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1504,
        0
      ],
      "id": "node_22"
    }
