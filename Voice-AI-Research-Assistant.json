          "__rl": true,
          "value": "YOUR_AIRTABLE_LOG_APP_ID",
          "mode": "id"
        },
        "table": {
          "__rl": true,
          "value": "YOUR_AIRTABLE_VOICELOGS_TABLE_ID",
          "mode": "id"
